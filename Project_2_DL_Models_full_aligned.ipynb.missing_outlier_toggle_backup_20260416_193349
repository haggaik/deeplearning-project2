    "            nn.Linear(64, 1)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        return self.net(x)\n",
    "\n",
    "torch_model = PyTorchDNN(INPUT_DIM).to(device)\n",
