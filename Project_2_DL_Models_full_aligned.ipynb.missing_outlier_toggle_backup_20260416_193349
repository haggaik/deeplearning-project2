    "def get_optimizer(name: str, learning_rate: float):\n",
    "    name = name.lower()\n",
    "    if name == \"sgd\":\n",
    "        return SGD(learning_rate=learning_rate)\n",
    "    if name == \"adam\":\n",
    "        return Adam(learning_rate=learning_rate)\n",
    "    if name == \"rmsprop\":\n",
    "        return RMSprop(learning_rate=learning_rate)\n",
    "    raise ValueError(f\"Unsupported optimizer: {name}\")\n",
    "\n",
    "def regression_metrics(y_true, y_pred):\n",
    "    mse = mean_squared_error(y_true, y_pred)\n",
    "    mae = mean_absolute_error(y_true, y_pred)\n",
    "    rmse = np.sqrt(mse)\n",
    "    r2 = r2_score(y_true, y_pred)\n",
    "    return {\"mse\": mse, \"mae\": mae, \"rmse\": rmse, \"r2\": r2}\n",
    "\n",
    "def plot_history(history, title: str):\n",
    "    plt.figure(figsize=(9, 5))\n",
    "    plt.plot(history.history[\"loss\"], label=\"train_loss\")\n",
    "    plt.plot(history.history[\"val_loss\"], label=\"val_loss\")\n",
    "    plt.title(title)\n",
    "    plt.xlabel(\"Epoch\")\n",
    "    plt.ylabel(\"Loss\")\n",
    "    plt.legend()\n",
    "    plt.show()\n",
    "\n",
    "def train_tf_experiment(model_name: str, loss_name: str, optimizer_name: str, learning_rate: float):\n",
    "    if model_name == \"Linear\":\n",
    "        model = build_linear_model(INPUT_DIM)\n",
    "    elif model_name == \"MLP\":\n",
    "        model = build_mlp_model(INPUT_DIM)\n",
    "    elif model_name == \"DNN\":\n",
    "        model = build_dnn_model(INPUT_DIM)\n",
    "    else:\n",
    "        raise ValueError(f\"Unknown model name: {model_name}\")\n",
    "\n",
    "    optimizer = get_optimizer(optimizer_name, learning_rate)\n",
    "\n",
    "    model.compile(\n",
    "        optimizer=optimizer,\n",
    "        loss=loss_name,\n",
    "        metrics=[\"mae\"]\n",
    "    )\n",
    "\n",
    "    start = time.time()\n",
    "    history = model.fit(\n",
    "        X_train_scaled,\n",
    "        y_train,\n",
    "        validation_data=(X_val_scaled, y_val),\n",
    "        epochs=EPOCHS,\n",
    "        batch_size=BATCH_SIZE,\n",
    "        verbose=0\n",
    "    )\n",
    "    elapsed = time.time() - start\n",
    "\n",
    "    y_pred = model.predict(X_val_scaled, verbose=0).ravel()\n",
    "    metrics = regression_metrics(y_val, y_pred)\n",
    "\n",
    "    result = {\n",
    "        \"model\": model_name,\n",
    "        \"loss\": loss_name.upper(),\n",
    "        \"optimizer\": optimizer_name.upper(),\n",
    "        \"learning_rate\": learning_rate,\n",
    "        \"epochs\": EPOCHS,\n",
    "        \"batch_size\": BATCH_SIZE,\n",
    "        \"train_time_sec\": elapsed,\n",
    "        \"val_mse\": metrics[\"mse\"],\n",
    "        \"val_mae\": metrics[\"mae\"],\n",
    "        \"val_rmse\": metrics[\"rmse\"],\n",
    "        \"val_r2\": metrics[\"r2\"],\n",
    "        \"final_train_loss\": history.history[\"loss\"][-1],\n",
    "        \"final_val_loss\": history.history[\"val_loss\"][-1],\n",
    "    }\n",
    "\n",
    "    return model, history, result, y_pred"
   ]
