    "def add_calendar_columns_inplace(df: pd.DataFrame, month: int) -> None:\n",
    "    # Avoid df.copy() (that doubles memory)\n",
    "    ymd = 2020 * 10000 + month * 100 + df[\"pickup_day\"].astype(\"int16\", copy=False)\n",
    "    df[\"pickup_date\"] = pd.to_datetime(ymd, format=\"%Y%m%d\", errors=\"coerce\")\n",
    "    df[\"pickup_datetime_proxy\"] = (\n",
    "        df[\"pickup_date\"]\n",
    "        + pd.to_timedelta(df[\"pickup_hour\"].astype(\"int16\", copy=False), unit=\"h\")\n",
    "    )\n",
    "\n",
    "add_calendar_columns_inplace(jan, 1)\n",
    "add_calendar_columns_inplace(mar, 3)\n",
    "add_calendar_columns_inplace(may, 5)\n",
    "\n",
    "taxi_all = pd.concat([jan, mar, may], ignore_index=True, copy=False)\n",
    "taxi_all.sort_values([\"pickup_date\", \"pickup_hour\"], inplace=True, kind=\"mergesort\")\n",
    "taxi_all.reset_index(drop=True, inplace=True)\n",
    "\n",
    "print(\"Combined taxi data shape:\", taxi_all.shape)\n",
    "print(\"Date range:\", taxi_all[\"pickup_date\"].min(), \"to\", taxi_all[\"pickup_date\"].max())\n",
    "display(taxi_all.head())\n"
   ]
  },
