    "\n",
    "def find_file(filename: str) -> Path:\n",
    "    for base in SEARCH_DIRS:\n",
    "        candidate = base / filename\n",
    "        if candidate.exists():\n",
    "            return candidate.resolve()\n",
    "    raise FileNotFoundError(f\"Could not find {filename} in: {[str(p) for p in SEARCH_DIRS]}\")\n",
