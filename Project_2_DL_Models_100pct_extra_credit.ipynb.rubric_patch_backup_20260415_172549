   "source": [
    "def build_linear_model(input_dim: int) -> keras.Model:\n",
    "    model = Sequential([\n",
    "        layers.Input(shape=(input_dim,)),\n",
    "        layers.Dense(1)\n",
    "    ], name=\"Linear_Regression\")\n",
    "    return model"
   ]
